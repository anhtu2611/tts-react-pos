# ============================================================
# TELEGRAM BOT CONFIG
# ============================================================
# Token từ @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID admin (nhiều ID cách nhau bằng dấu phẩy)
# Lấy ID: nhắn tin cho @userinfobot
ADMIN_USER_IDS=123456789,987654321

# Channel đăng bài (bắt đầu bằng @ hoặc -100...)
TELEGRAM_PUBLISH_CHANNEL=@your_channel_here

# ============================================================
# TELEGRAM CRAWLER (GramJS - tài khoản user)
# ============================================================
# Lấy từ https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Session string (tạo bằng: npm run telegram-auth)
TELEGRAM_SESSION_STRING=

# Danh sách channel cần crawl (cách nhau bằng dấu phẩy)
# Dùng username (@channel) hoặc ID số
TELEGRAM_SOURCE_CHANNELS=@channel1,@channel2

# Thời gian gộp tin từ cùng nguồn (giây) - mặc định 180 (3 phút)
TELEGRAM_BUFFER_SECONDS=180

# ============================================================
# TWITTER CRAWLER CONFIG
# ============================================================
# Bearer token để đọc tweets (không cần OAuth)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Danh sách tài khoản Twitter cần crawl (cách nhau bằng dấu phẩy, không có @)
TWITTER_SOURCE_ACCOUNTS=account1,account2,account3

# ============================================================
# TWITTER PUBLISHER - TÀI KHOẢN TIẾNG VIỆT
# ============================================================
TWITTER_VI_API_KEY=your_api_key
TWITTER_VI_API_SECRET=your_api_secret
TWITTER_VI_ACCESS_TOKEN=your_access_token
TWITTER_VI_ACCESS_SECRET=your_access_secret

# ============================================================
# TWITTER PUBLISHER - TÀI KHOẢN TIẾNG ANH
# ============================================================
TWITTER_EN_API_KEY=your_api_key
TWITTER_EN_API_SECRET=your_api_secret
TWITTER_EN_ACCESS_TOKEN=your_access_token
TWITTER_EN_ACCESS_SECRET=your_access_secret

# ============================================================
# DEEPSEEK AI CONFIG
# ============================================================
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
# Model mặc định: deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="file:./data/bot.db"

# ============================================================
# SCHEDULER (giây)
# ============================================================
CRAWL_INTERVAL_SECONDS=60
PROCESS_INTERVAL_SECONDS=15
PUBLISH_TELEGRAM_INTERVAL_SECONDS=5
PUBLISH_TWITTER_INTERVAL_SECONDS=20
